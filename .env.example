# Database
DB_PATH=covid_nz_news.db

# Cache
CACHE_DIR=warc_cache

# Common Crawl Configuration
CRAWL_ID=CC-MAIN-2020-16
DOMAIN_PATTERN=*.nzherald.co.nz/

# COVID-related keywords (comma-separated)
COVID_KEYWORDS=covid,coronavirus,virus,lockdown,vaccine,quarantine

# Processing limits
MAX_WARC_FILES=10
MAX_CONTENT_LENGTH=50000
MIN_TEXT_LENGTH=100

# Network settings
CDX_TIMEOUT=60
WARC_TIMEOUT=300
RETRY_ATTEMPTS=3
RETRY_DELAY=2.0

# Logging
LOG_LEVEL=INFO
LOG_FILE=covid_nz_news.log

# Language filtering (comma-separated language codes)
ALLOWED_LANGUAGES=en
